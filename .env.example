# Firebase Config (injected at build time via import.meta.env)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Database Configuration (Postgres/Cloud SQL)
SQL_HOST="127.0.0.1"
SQL_USER="postgres"
SQL_PASSWORD="password"
SQL_DB_NAME="sugardaddy"
SQL_ADMIN_USER="postgres"
SQL_ADMIN_PASSWORD="password"

# Stripe Secrets for server-side financial flows
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Environment
NODE_ENV="development"